extends layout

block content
  .page-header
    h2.page-title Inventory
    a.btn.btn-primary(href='/inventory/add') + Add Drug

  .card
    .table-wrapper
      table.mobile-stack
        thead
          tr
            th Drug Name
            th Category
            th Stock
            th Reorder Point
            th Nearest Expiry
            th Status
            th Actions
        tbody#inventory-table
          tr
            td(colspan='7' style='text-align:center;color:#6c757d') Loading...

block scripts
  script.

    fetch('/api/inventory', { credentials: 'include' })
    .then(r => r.json())
    .then(data => {
      const drugs = data.drugs || [];
      const tbody = document.getElementById('inventory-table');

      if (!drugs.length) {
        tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:#6c757d">No drugs in inventory</td></tr>';
        return;
      }

      tbody.innerHTML = drugs.map(d => {
        const nearest = d.batches.length
          ? new Date(d.batches[0].expiry_date).toLocaleDateString('en-NG')
          : 'N/A';
        const isLow = d.total_quantity <= d.reorder_point;
        return `
          <tr>
            <td data-label="Drug"><strong>${d.drug_name}</strong><br><small style="color:#8492a6">${d.generic_name || ''}</small></td>
            <td data-label="Category">${d.category || '—'}</td>
            <td data-label="Stock" style="color:${isLow ? 'var(--danger)' : 'var(--success)'};font-weight:600">${d.total_quantity} ${d.unit}</td>
            <td data-label="Reorder Point">${d.reorder_point}</td>
            <td data-label="Nearest Expiry">${nearest}</td>
            <td data-label="Status"><span class="badge ${isLow ? 'badge-low' : 'badge-ok'}">${isLow ? 'Low Stock' : 'OK'}</span></td>
            <td data-label="Action"><a href="/inventory/${d._id}" class="btn btn-sm btn-primary">View</a></td>
          </tr>
        `;
      }).join('');
    });   