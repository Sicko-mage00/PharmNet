extends layout

block content
  .page-header
    h2.page-title Inventory
    a.btn.btn-primary(href='/inventory/add') + Add Drug

  .card
    .table-wrapper
      table
        thead
          tr
            th Drug Name
            th Category
            th Stock
            th Reorder Point
            th Nearest Expiry
            th Status
            th Actions
        tbody#inventory-table
          tr
            td(colspan='7' style='text-align:center;color:#6c757d') Loading...

block scripts
  script.
    const token = getToken();

    fetch('/api/inventory', {
      headers: { 'Authorization': `Bearer ${token}` }
    })
    .then(r => r.json())
    .then(data => {
      const drugs = data.drugs || [];
      const tbody = document.getElementById('inventory-table');

      if (!drugs.length) {
        tbody.innerHTML = '<tr><td colspan="7" style="text-align:center;color:#6c757d">No drugs in inventory</td></tr>';
        return;
      }

      tbody.innerHTML = drugs.map(d => {
        const nearest = d.batches.length ? new Date(d.batches[0].expiry_date).toLocaleDateString() : 'N/A';
        const isLow   = d.total_quantity <= d.reorder_point;
        return `
          <tr>
            <td><strong>${d.drug_name}</strong><br><small style="color:#6c757d">${d.generic_name || ''}</small></td>
            <td>${d.category || '—'}</td>
            <td style="color:${isLow ? '#dc3545' : '#28a745'};font-weight:600">${d.total_quantity} ${d.unit}</td>
            <td>${d.reorder_point}</td>
            <td>${nearest}</td>
            <td><span class="badge ${isLow ? 'badge-declined' : 'badge-resolved'}">${isLow ? 'Low Stock' : 'OK'}</span></td>
            <td>
              <a href="/inventory/${d._id}" class="btn btn-sm btn-primary">View</a>
            </td>
          </tr>
        `;
      }).join('');
    });