doctype html
html(lang='en')
  head
    meta(charset='UTF-8')
    meta(name='viewport', content='width=device-width, initial-scale=1.0')
    title= title || 'PharmaNet'
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin)
    link(rel='stylesheet' href='https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300..700;1,9..40,300..700&family=DM+Mono:wght@400;500&display=swap')
    link(rel='stylesheet' href='/css/style.css')

  body
    if user
      .app-shell
        aside.sidebar
          .sidebar-brand
            .brand-icon ⚕
            span PharmaNet

          nav.sidebar-nav
            a.nav-item(href='/scan')
              svg(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2')
                path(d='M3 7V5a2 2 0 012-2h2M17 3h2a2 2 0 012 2v2M21 17v2a2 2 0 01-2 2h-2M7 21H5a2 2 0 01-2-2v-2')
                line(x1='7' y1='12' x2='7' y2='12')
                line(x1='12' y1='12' x2='17' y2='12')
                line(x1='12' y1='7' x2='12' y2='17')
              span Scan Drug

            a.nav-item(href='/inventory')
              svg(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2')
                path(d='M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z')
              span Inventory

            a.nav-item(href='/alerts')
              svg(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2')
                path(d='M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9')
                path(d='M13.73 21a2 2 0 01-3.46 0')
              span Alerts
              span.nav-badge#alert-count

            a.nav-item(href='/dashboard')
              svg(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2')
                rect(x='3' y='3' width='7' height='7')
                rect(x='14' y='3' width='7' height='7')
                rect(x='3' y='14' width='7' height='7')
                rect(x='14' y='14' width='7' height='7')
              span Dashboard

            if user && user.role === 'super_admin'
              .nav-divider
              a.nav-item(href='/admin')
                svg(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2')
                  circle(cx='12' cy='8' r='4')
                  path(d='M6 20v-2a4 4 0 014-4h4a4 4 0 014 4v2')
                span Admin Setup
              a.nav-item(href='/facilities')
                svg(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2')
                  path(d='M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z')
                span Facilities
              a.nav-item(href='/keys')
                svg(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2')
                  path(d='M21 2l-2 2m-7.61 7.61a5.5 5.5 0 11-7.778 7.778 5.5 5.5 0 017.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4')
                span Keys

          .sidebar-footer
            a.nav-item(href='/profile')
              svg(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2')
                path(d='M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2')
                circle(cx='12' cy='7' r='4')
              span Profile
            a.nav-item#logout-btn(href='#')
              svg(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2')
                path(d='M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4')
                polyline(points='16 17 21 12 16 7')
                line(x1='21' y1='12' x2='9' y2='12')
              span Logout

        .main-area
          header.topbar
            .topbar-left
              button.sidebar-toggle#sidebar-toggle
                svg(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' width='20' height='20')
                  line(x1='3' y1='12' x2='21' y2='12')
                  line(x1='3' y1='6' x2='21' y2='6')
                  line(x1='3' y1='18' x2='21' y2='18')
              h1.topbar-title= title || 'PharmaNet'

            .topbar-right
              .topbar-facility#topbar-facility —
              .topbar-user
                .user-avatar#user-avatar ?
                .user-info
                  span.user-name#user-name Loading...
                  span.user-role#user-role —

          main.page-content
            block content

    else
      block content

    script(src='/js/main.js')
    block scripts