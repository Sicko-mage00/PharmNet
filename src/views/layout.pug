doctype html
html(lang='en')
  head
    meta(charset='UTF-8')
    meta(name='viewport', content='width=device-width, initial-scale=1.0')
    title= title || 'PharmaNet'
    link(rel='preconnect' href='https://fonts.googleapis.com')
    link(rel='preconnect' href='https://fonts.gstatic.com' crossorigin)
    link(rel='stylesheet' href='https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,300..700&family=DM+Mono:wght@400;500&display=swap')
    link(rel='stylesheet' href='/css/style.css')

  body
    if user
      .app-shell
        aside.sidebar#sidebar
          .sidebar-brand
            svg.brand-svg(viewBox='0 0 36 36' fill='none' xmlns='http://www.w3.org/2000/svg')
              rect(width='36' height='36' rx='8' fill='#0052CC')
              path(d='M18 8v20M8 18h20' stroke='white' stroke-width='3' stroke-linecap='round')
            span PharmaNet

          nav.sidebar-nav
            a.nav-item(href='/dashboard')
              svg(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.8')
                rect(x='3' y='3' width='7' height='7' rx='1')
                rect(x='14' y='3' width='7' height='7' rx='1')
                rect(x='3' y='14' width='7' height='7' rx='1')
                rect(x='14' y='14' width='7' height='7' rx='1')
              span Dashboard

            a.nav-item(href='/scan')
              svg(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.8')
                path(d='M3 7V5a2 2 0 012-2h2')
                path(d='M17 3h2a2 2 0 012 2v2')
                path(d='M21 17v2a2 2 0 01-2 2h-2')
                path(d='M7 21H5a2 2 0 01-2-2v-2')
                line(x1='7' y1='12' x2='9' y2='12')
                line(x1='12' y1='7' x2='12' y2='9')
                line(x1='15' y1='12' x2='17' y2='12')
                line(x1='12' y1='15' x2='12' y2='17')
              span Scan Drug

            a.nav-item(href='/inventory')
              svg(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.8')
                path(d='M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z')
                polyline(points='3.27 6.96 12 12.01 20.73 6.96')
                line(x1='12' y1='22.08' x2='12' y2='12')
              span Inventory

            a.nav-item(href='/alerts')
              svg(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.8')
                path(d='M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9')
                path(d='M13.73 21a2 2 0 01-3.46 0')
              span Alerts
              span.nav-badge#alert-count

            if user && user.role === 'super_admin'
              .nav-divider
              a.nav-item(href='/admin')
                svg(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.8')
                  path(d='M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z')
                span Admin Setup
              a.nav-item(href='/facilities')
                svg(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.8')
                  path(d='M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z')
                  polyline(points='9 22 9 12 15 12 15 22')
                span Facilities

          .sidebar-footer
            a.nav-item(href='/profile')
              svg(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.8')
                path(d='M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2')
                circle(cx='12' cy='7' r='4')
              span Profile
            a.nav-item#logout-btn(href='#')
              svg(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.8')
                path(d='M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4')
                polyline(points='16 17 21 12 16 7')
                line(x1='21' y1='12' x2='9' y2='12')
              span Logout

        .main-area
          header.topbar
            .topbar-left
              button.sidebar-toggle#sidebar-toggle(aria-label='Toggle menu')
                svg(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' width='20' height='20')
                  line(x1='3' y1='12' x2='21' y2='12')
                  line(x1='3' y1='6' x2='21' y2='6')
                  line(x1='3' y1='18' x2='21' y2='18')
              .topbar-brand
                h1.topbar-title= title || 'PharmaNet'
                span.topbar-facility-name#topbar-facility-name

            .topbar-right
              .topbar-facility#topbar-facility —

              a.topbar-alert-btn#topbar-alert-btn(href='/alerts')
                svg(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='1.8' width='20' height='20')
                  path(d='M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9')
                  path(d='M13.73 21a2 2 0 01-3.46 0')
                span.topbar-alert-dot#topbar-alert-dot

              a.topbar-user(href='/profile')
                .user-avatar#user-avatar ?
                .user-info
                  span.user-name#user-name Loading...
                  span.user-role#user-role —

          main.page-content
            block content

    else
      block content

    script(src='/js/main.js')
    block scripts