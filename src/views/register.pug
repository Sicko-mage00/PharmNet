extends layout

block content
  .auth-wrapper
    .auth-card
      h1 PharmaNet
      p Create your account

      form#register-form
        .form-group
          label First Name
          input.form-control(
            type='text'
            id='firstName'
            placeholder='Enter your first name'
            required
          )
        .form-group
          label Last Name
          input.form-control(
            type='text'
            id='lastName'
            placeholder='Enter your last name'
            required
          )
        .form-group
          label Email
          input.form-control(
            type='email'
            id='email'
            placeholder='Enter your email'
            required
          )
        .form-group
          label Phone
          input.form-control(
            type='tel'
            id='phone'
            placeholder='e.g 08012345678'
            required
          )
        .form-group
          label(for='password')  Password
          .input-wrapper
            input.form-control(
                type='password'
                id='password'
                placeholder='Minimum 8 characters'
                required
            )
            span.toggle-password#toggle-password
                svg(xmlns='http://www.w3.org/2000/svg' width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round')
                    path(d='M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z')
                    circle(cx='12' cy='12' r='3')
                

        .form-group
          label Confirm Password
          .input-wrapper
            input.form-control(
                type='password'
                id='confirmPassword'
                placeholder='Repeat your password'
                required
            )
            span.toggle-password#toggle-confirm
                svg(xmlns='http://www.w3.org/2000/svg' width='18' height='18' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round')
                    path(d='M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z')
                    circle(cx='12' cy='12' r='3')

        button.btn.btn-primary(type='submit') Create Account

      p(style='text-align:center; margin-top:1rem; font-size:0.9rem')
        | Already have an account?
        a(href='/login') &nbsp;Login

block scripts
  script.
    const form = document.getElementById('register-form');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const firstName       = document.getElementById('firstName').value;
      const lastName        = document.getElementById('lastName').value;
      const email           = document.getElementById('email').value;
      const phone           = document.getElementById('phone').value;
      const password        = document.getElementById('password').value;
      const confirmPassword = document.getElementById('confirmPassword').value;

      if (password !== confirmPassword) {
        alert('Passwords do not match');
        return;
      }

      try {
        const res = await fetch('/api/auth/register', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ firstName, lastName, email, phone, password }),
        });

        const data = await res.json();

        if (res.ok) {
          localStorage.setItem('user', JSON.stringify({
            name: data.name,
            role: data.role,
          }));
          window.location.href = '/verify';
        } else {
          alert(data.message || 'Registration failed');
        }
      } catch (err) {
        alert('Something went wrong');
      }
    });

    togglePassword('toggle-password', 'password');
    togglePassword('toggle-confirm', 'confirmPassword');