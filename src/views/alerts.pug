extends layout

block content
  .page-header
    h2.page-title Alerts

  #alerts-container
    .loader
      .spinner
      |  Loading...

block scripts
  script.
    document.addEventListener('DOMContentLoaded', () => {
      const user = getUser();

      const loadAlerts = () => {
        fetch('/api/alerts', { credentials: 'include' })
          .then(r => r.json())
          .then(data => {
            const alerts    = data.alerts || [];
            const container = document.getElementById('alerts-container');

            if (!alerts.length) {
              container.innerHTML = `
                <div class="empty-state">
                  <div class="empty-state-icon">🔔</div>
                  <p>No active alerts</p>
                </div>`;
              return;
            }

            container.innerHTML = alerts.map(a => {
              const myFacilityId  = user && user.facilityId;
              const sourceFacId   = a.source_facility && a.source_facility._id;
              const targetFacId   = a.target_facility && a.target_facility._id;
              const isSource      = sourceFacId === myFacilityId;
              const isTarget      = targetFacId === myFacilityId;
              const isSelfAlert   = sourceFacId === targetFacId;

              let actions = '';

              if (a.status === 'pending' && isSource && !isSelfAlert) {
                actions += `<button class="btn btn-success btn-sm" onclick="doAlert('${a._id}','confirm')">✓ Confirm</button>`;
                actions += `<button class="btn btn-danger btn-sm" onclick="doAlert('${a._id}','decline')">✗ Decline</button>`;
              }
              if (a.status === 'confirmed' && isSource) {
                actions += `<button class="btn btn-primary btn-sm" onclick="doAlert('${a._id}','dispatch')">📦 Mark Dispatched</button>`;
              }
              if (a.status === 'dispatched' && isTarget) {
                actions += `<button class="btn btn-success btn-sm" onclick="resolveWithBatch('${a._id}')">✓ Mark Received</button>`;
              }
              if (['pending', 'confirmed'].includes(a.status) && isTarget) {
                actions += `<button class="btn btn-ghost btn-sm" onclick="doAlert('${a._id}','self-resolve')">Self Resolve</button>`;
              }

              const typeLabel = a.type === 'ROP'
                ? `<span style="color:var(--danger);font-weight:700">🔴 ROP</span>`
                : `<span style="color:var(--warning);font-weight:700">🟡 FEFO</span>`;

              return `
                <div class="alert-card ${a.type}">
                  <div class="alert-card-header">
                    <span class="alert-card-title">${typeLabel} — ${a.drug_name || '—'}</span>
                    <span class="badge badge-${a.status}">${a.status}</span>
                  </div>
                  <div class="alert-card-body">
                    <p>
                      <strong>From:</strong> ${a.source_facility ? a.source_facility.name : '—'}
                      &nbsp;→&nbsp;
                      <strong>To:</strong> ${a.target_facility ? a.target_facility.name : '—'}
                    </p>
                    ${a.quantity_needed   ? `<p>📉 <strong>Needed:</strong> ${a.quantity_needed} units</p>`   : ''}
                    ${a.quantity_available? `<p>📦 <strong>Available:</strong> ${a.quantity_available} units</p>` : ''}
                    ${a.expiry_date       ? `<p>📅 <strong>Expiry:</strong> ${new Date(a.expiry_date).toLocaleDateString('en-NG')}</p>` : ''}
                    ${a.notes             ? `<p>📝 <strong>Note:</strong> ${a.notes}</p>` : ''}
                    ${isSelfAlert         ? `<p style="color:var(--warning);font-size:0.8rem">⚠ No network match found — consider external procurement</p>` : ''}
                    <p style="font-size:0.78rem;color:#8492a6;margin-top:0.4rem">${new Date(a.created_at).toLocaleString('en-NG')}</p>
                  </div>
                  ${actions ? `<div class="alert-card-footer">${actions}</div>` : ''}
                </div>
              `;
            }).join('');
          })
          .catch(() => {
            document.getElementById('alerts-container').innerHTML =
              '<div class="flash flash-error">Failed to load alerts</div>';
          });
      };

      loadAlerts();

      const showError = (msg) => {
        const container = document.getElementById('alerts-container');
        const el = document.createElement('div');
        el.className = 'flash flash-error';
        el.style.marginBottom = '1rem';
        el.textContent = msg;
        container.prepend(el);
        setTimeout(() => el.remove(), 4000);
      };

      const doAlert = async (id, action) => {
        const body = action === 'dispatch'     ? { notes: 'Drugs dispatched' }
                  : action === 'self-resolve' ? { notes: 'Resolved externally' }
                  : {};
        const res  = await fetch(`/api/alerts/${id}/${action}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify(body),
        });
        const data = await res.json();
        if (res.ok) loadAlerts();
        else showError(data.message || 'Action failed');
      };

      window.resolveWithBatch = (id) => {
        // Show in-app modal instead of prompt()
        const modal = document.createElement('div');
        modal.className = 'modal-backdrop';
        modal.style.display = 'flex';
        modal.innerHTML = `
          <div class="modal-box" style="max-width:420px">
            <div class="modal-header">
              <h3>Confirm Receipt</h3>
              <button class="modal-close" onclick="this.closest('.modal-backdrop').remove()">✕</button>
            </div>
            <p style="font-size:0.875rem;color:#8492a6;margin-bottom:1rem">
              Enter the batch number you added to your inventory after receiving the drugs.
            </p>
            <div class="form-group">
              <label>Batch Number</label>
              <input class="form-control" id="resolve-batch" placeholder="e.g LGH-BATCH001" />
            </div>
            <div id="resolve-result"></div>
            <div class="modal-footer">
              <button class="btn btn-ghost" onclick="this.closest('.modal-backdrop').remove()">Cancel</button>
              <button class="btn btn-success" onclick="submitResolve('${id}', this)">✓ Mark Received</button>
            </div>
          </div>`;
        document.body.appendChild(modal);
      };

      window.submitResolve = async (id, btn) => {
        const batch_number = document.getElementById('resolve-batch').value.trim();
        const result       = document.getElementById('resolve-result');

        if (!batch_number) {
          result.innerHTML = '<div class="flash flash-error" style="margin-top:0.5rem">Batch number is required</div>';
          return;
        }

        btn.disabled = true;
        btn.textContent = 'Saving...';

        const res  = await fetch(`/api/alerts/${id}/resolve`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({ batch_number, notes: 'Drugs received' }),
        });
        const data = await res.json();

        if (res.ok) {
          document.querySelector('.modal-backdrop')?.remove();
          loadAlerts();
        } else {
          result.innerHTML = `<div class="flash flash-error" style="margin-top:0.5rem">${data.message || 'Failed to resolve'}</div>`;
          btn.disabled = false;
          btn.textContent = '✓ Mark Received';
        }
      };

      // auto-refresh every 15 seconds
      setInterval(loadAlerts, 15000);
    });