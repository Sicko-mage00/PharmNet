extends layout

block content
  .page-header
    h2.page-title Facilities
    button.btn.btn-primary#show-create-btn(onclick='toggleCreate()') + Add Facility

  #fac-flash

  .card#create-card(style='display:none')
    .card-title Create New Facility
    form#facility-form
      .form-row
        .form-group
          label Facility Name
          input.form-control(type='text' id='f-name' placeholder='e.g Lagos General Hospital' required)
        .form-group
          label Type
          select.form-control#f-type
            option(value='hospital') Hospital
            option(value='pharmacy') Pharmacy
            option(value='clinic') Clinic
            option(value='warehouse') Warehouse
      .form-row
        .form-group
          label Phone
          input.form-control(type='tel' id='f-phone' placeholder='e.g 08012345678' required)
        .form-group
          label Street (optional)
          input.form-control(type='text' id='f-street' placeholder='e.g 12 Marina Road')
      .form-row
        .form-group
          label City
          input.form-control(type='text' id='f-city' placeholder='e.g Lagos' required)
        .form-group
          label State
          input.form-control(type='text' id='f-state' placeholder='e.g Lagos' required)
      .form-group
        button.btn.btn-primary(type='submit') Create Facility
        button.btn.btn-ghost(type='button' onclick='toggleCreate()' style='margin-left:0.5rem') Cancel
    #facility-result

  .card
    .card-title
      span All Facilities
      .card-title-actions
        select.form-control#filter-type(style='width:auto;font-size:0.8rem' onchange='applyFilters()')
          option(value='') All Types
          option(value='hospital') Hospital
          option(value='pharmacy') Pharmacy
          option(value='clinic') Clinic
          option(value='warehouse') Warehouse
        select.form-control#filter-network(style='width:auto;font-size:0.8rem;margin-left:0.5rem' onchange='applyFilters()')
          option(value='') All Status
          option(value='true') Active
          option(value='false') Inactive
        button.btn.btn-sm.btn-ghost(onclick='loadFacilities()' style='margin-left:0.5rem') ↻

    .table-wrapper
      table.mobile-stack
        thead
          tr
            th Name
            th Type
            th City
            th Phone
            th Network
            th Actions
        tbody#facilities-table
          tr
            td(colspan='6')
              .loader
                .spinner
                |  Loading...

  //- Edit modal
  .modal-backdrop#edit-modal(style='display:none')
    .modal-box
      .modal-header
        h3 Edit Facility
        button.modal-close(onclick="document.getElementById('edit-modal').style.display='none'") ✕
      .form-group
        label Facility Name
        input.form-control#edit-name
      .form-group
        label Phone
        input.form-control#edit-phone
      .form-group
        label City
        input.form-control#edit-city
      .form-group
        label State
        input.form-control#edit-state
      input(type='hidden' id='edit-id')
      #edit-result
      .modal-footer
        button.btn.btn-ghost(onclick="document.getElementById('edit-modal').style.display='none'") Cancel
        button.btn.btn-primary(onclick='saveEdit()') Save Changes

block scripts
  script.
    document.addEventListener('DOMContentLoaded', () => {
      let allFacilities = [];

      const showFlash = (msg, type = 'success') => {
        const el = document.getElementById('fac-flash');
        el.innerHTML = `<div class="flash flash-${type}" style="margin-bottom:1rem">${msg}</div>`;
        setTimeout(() => el.innerHTML = '', 4000);
      };

      window.toggleCreate = () => {
        const card = document.getElementById('create-card');
        card.style.display = card.style.display === 'none' ? 'block' : 'none';
      };

      window.loadFacilities = () => {
        fetch('/api/facilities', { credentials: 'include' })
          .then(r => r.json())
          .then(data => {
            allFacilities = data.facilities || [];
            applyFilters();
          });
      };

      window.applyFilters = () => {
        const typeF    = document.getElementById('filter-type').value;
        const networkF = document.getElementById('filter-network').value;
        let filtered   = allFacilities;
        if (typeF)    filtered = filtered.filter(f => f.type === typeF);
        if (networkF) filtered = filtered.filter(f => String(f.isNetworkMember) === networkF);
        renderFacilities(filtered);
      };

      const renderFacilities = (facilities) => {
        const tbody = document.getElementById('facilities-table');
        if (!facilities.length) {
          tbody.innerHTML = '<tr><td colspan="6"><div class="empty-state"><p>No facilities found</p></div></td></tr>';
          return;
        }
        tbody.innerHTML = facilities.map(f => `
          <tr>
            <td data-label="Name"><strong>${f.name}</strong></td>
            <td data-label="Type">${f.type}</td>
            <td data-label="City">${f.address ? f.address.city : '—'}</td>
            <td data-label="Phone">${f.phone}</td>
            <td data-label="Network">
              <span class="badge ${f.isNetworkMember ? 'badge-ok' : 'badge-expired'}">
                ${f.isNetworkMember ? 'Active' : 'Inactive'}
              </span>
            </td>
            <td data-label="Actions" style="white-space:nowrap">
              <button class="btn btn-sm btn-ghost" onclick="openEdit('${f._id}','${f.name.replace(/'/g,"\\'")}','${f.phone}','${f.address ? f.address.city : ''}','${f.address ? f.address.state : ''}')">Edit</button>
              <button class="btn btn-sm btn-ghost" onclick="goKeys('${f._id}','${f.name.replace(/'/g,"\\'")}')" style="margin-left:0.3rem">🔑 Key</button>
              <button class="btn btn-sm btn-danger" onclick="deleteFacility('${f._id}','${f.name.replace(/'/g,"\\'")}')" style="margin-left:0.3rem">Delete</button>
            </td>
          </tr>
        `).join('');
      };

      window.goKeys = (id, name) => {
        window.location.href = `/admin/keys?facility_id=${id}&facility_name=${encodeURIComponent(name)}`;
      };

      window.openEdit = (id, name, phone, city, state) => {
        document.getElementById('edit-id').value    = id;
        document.getElementById('edit-name').value  = name;
        document.getElementById('edit-phone').value = phone;
        document.getElementById('edit-city').value  = city;
        document.getElementById('edit-state').value = state;
        document.getElementById('edit-result').innerHTML = '';
        document.getElementById('edit-modal').style.display = 'flex';
      };

      window.saveEdit = async () => {
        const id  = document.getElementById('edit-id').value;
        const res = await fetch(`/api/facilities/${id}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({
            name:    document.getElementById('edit-name').value,
            phone:   document.getElementById('edit-phone').value,
            address: {
              city:  document.getElementById('edit-city').value,
              state: document.getElementById('edit-state').value,
            },
          }),
        });
        const data = await res.json();
        if (res.ok) {
          document.getElementById('edit-modal').style.display = 'none';
          showFlash('Facility updated');
          loadFacilities();
        } else {
          document.getElementById('edit-result').innerHTML =
            `<div class="flash flash-error" style="margin-top:0.75rem">${data.message}</div>`;
        }
      };

      window.deleteFacility = async (id, name) => {
        const confirmed = await showConfirm(`Delete <strong>${name}</strong>? This cannot be undone.`);
        if (!confirmed) return;
        const res  = await fetch(`/api/admin/facilities/${id}`, {
          method: 'DELETE', credentials: 'include',
        });
        const data = await res.json();
        if (res.ok) { showFlash('Facility deleted'); loadFacilities(); }
        else showFlash(data.message || 'Failed', 'error');
      };

      // In-app confirm — returns promise
      window.showConfirm = (msg) => {
        return new Promise(resolve => {
          const el = document.createElement('div');
          el.className = 'modal-backdrop';
          el.style.display = 'flex';
          el.innerHTML = `
            <div class="modal-box" style="max-width:380px;text-align:center">
              <p style="font-size:0.95rem;margin-bottom:1.25rem">${msg}</p>
              <div style="display:flex;gap:0.75rem;justify-content:center">
                <button class="btn btn-ghost" id="conf-no">Cancel</button>
                <button class="btn btn-danger" id="conf-yes">Confirm Delete</button>
              </div>
            </div>`;
          document.body.appendChild(el);
          el.querySelector('#conf-yes').onclick = () => { document.body.removeChild(el); resolve(true);  };
          el.querySelector('#conf-no').onclick  = () => { document.body.removeChild(el); resolve(false); };
        });
      };

      document.getElementById('facility-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const result = document.getElementById('facility-result');
        result.innerHTML = '<div class="loader"><div class="spinner"></div> Creating...</div>';

        const res = await fetch('/api/facilities', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({
            name:    document.getElementById('f-name').value,
            type:    document.getElementById('f-type').value,
            phone:   document.getElementById('f-phone').value,
            address: {
              street: document.getElementById('f-street').value,
              city:   document.getElementById('f-city').value,
              state:  document.getElementById('f-state').value,
            },
          }),
        });
        const data = await res.json();
        if (res.ok) {
          result.innerHTML = `<div class="flash flash-success" style="margin-top:1rem">✓ <strong>${data.facility.name}</strong> created</div>`;
          document.getElementById('facility-form').reset();
          toggleCreate();
          loadFacilities();
        } else {
          result.innerHTML = `<div class="flash flash-error" style="margin-top:1rem">${data.message}</div>`;
        }
      });

      loadFacilities();
    });