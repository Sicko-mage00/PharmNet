extends layout

block content
  .stats-grid
    a.stat-card(href='/inventory' style='text-decoration:none;cursor:pointer')
      .stat-icon.blue
        svg(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' width='22' height='22')
          path(d='M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z')
      .stat-info
        .stat-number#total-drugs 0
        .stat-label Total Drugs

    a.stat-card(href='/inventory' style='text-decoration:none;cursor:pointer')
      .stat-icon.red
        svg(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' width='22' height='22')
          polyline(points='22 12 18 12 15 21 9 3 6 12 2 12')
      .stat-info
        .stat-number#low-stock 0
        .stat-label Low Stock

    a.stat-card(href='/inventory' style='text-decoration:none;cursor:pointer')
      .stat-icon.orange
        svg(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' width='22' height='22')
          circle(cx='12' cy='12' r='10')
          polyline(points='12 6 12 12 16 14')
      .stat-info
        .stat-number#expiring 0
        .stat-label Expiring Soon

    a.stat-card(href='/sales' style='text-decoration:none;cursor:pointer')
      .stat-icon.green
        svg(viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' width='22' height='22')
          circle(cx='9' cy='21' r='1')
          circle(cx='20' cy='21' r='1')
          path(d='M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 001.95-1.57L23 6H6')
      .stat-info
        .stat-number#total-sales 0
        .stat-label Sales Today

  .grid-2
  .card
    .card-title
      span Recent Sales
      a.btn.btn-sm.btn-ghost(href='/sales') View All
    .table-wrapper
      table.mobile-stack
        thead
          tr
            th Drug
            th Quantity Sold
            th ROP Alert
            th Time
        tbody#recent-sales
          tr
            td(colspan='4')
              .loader
                .spinner
                |  Loading...

  .card
    .card-title
      span Active Alerts
      a.btn.btn-sm.btn-ghost(href='/alerts') View All
    #recent-alerts
      .loader
        .spinner
        |  Loading...

block scripts
  script.
    document.addEventListener('DOMContentLoaded', () => {

      fetch('/api/inventory', { credentials: 'include' })
        .then(r => r.json())
        .then(data => {
          const drugs   = data.drugs || [];
          const today   = new Date();

          const lowStock = drugs.filter(d => d.total_quantity <= d.reorder_point).length;
          const expiring = drugs.filter(d => {
            if (!d.batches.length) return false;
            const days = Math.ceil((new Date(d.batches[0].expiry_date) - today) / 86400000);
            return days > 0 && days <= d.expiry_alert_days;
          }).length;

          countUp(document.getElementById('total-drugs'), drugs.length);
          countUp(document.getElementById('low-stock'),   lowStock);
          countUp(document.getElementById('expiring'),    expiring);
        });

      fetch('/api/sales', { credentials: 'include' })
        .then(r => r.json())
        .then(data => {
          const sales = data.sales || [];
          const today = new Date().toDateString();
          const todaySales = sales.filter(s => new Date(s.created_at).toDateString() === today);

          countUp(document.getElementById('total-sales'), todaySales.length);

          const tbody = document.getElementById('recent-sales');
          if (!sales.length) {
            tbody.innerHTML = `<tr><td colspan="4"><div class="empty-state"><div class="empty-state-icon">🛒</div><p>No sales yet today</p></div></td></tr>`;
            return;
          }
          tbody.innerHTML = sales.slice(0, 6).map((s, i) => `
            <tr style="animation-delay:${i * 0.05}s">
              <td data-label="Drug"><strong>${s.snapshot.drug_name}</strong></td>
              <td data-label="Qty Sold">${s.quantity_sold} units</td>
              <td data-label="ROP Alert"><span class="badge ${s.snapshot.rop_triggered ? 'badge-low' : 'badge-ok'}">${s.snapshot.rop_triggered ? 'Triggered' : 'Normal'}</span></td>
              <td data-label="Time" style="color:#8492a6">${new Date(s.created_at).toLocaleTimeString('en-NG', { hour:'2-digit', minute:'2-digit' })}</td>
            </tr>
          `).join('');
        });

      fetch('/api/alerts', { credentials: 'include' })
        .then(r => r.json())
        .then(data => {
          const alerts  = data.alerts || [];
          const wrapper = document.getElementById('recent-alerts');

          if (!alerts.length) {
            wrapper.innerHTML = `<div class="empty-state"><div class="empty-state-icon">🔔</div><p>No active alerts</p></div>`;
            return;
          }

          wrapper.innerHTML = alerts.slice(0, 3).map(a => `
            <div class="alert-card ${a.type}">
              <div class="alert-card-header">
                <span class="alert-card-title">${a.type} — ${a.drug_name}</span>
                <span class="badge badge-${a.status}">${a.status}</span>
              </div>
              <div class="alert-card-body">
                ${a.type === 'ROP'
                  ? `Needs <strong>${a.quantity_needed}</strong> units`
                  : `<strong>${a.quantity_available}</strong> units expiring ${new Date(a.expiry_date).toLocaleDateString()}`
                }
              </div>
            </div>
          `).join('');
        });
    });