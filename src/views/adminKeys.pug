extends layout

block content
  .page-header
    h2.page-title Facility Keys

  #key-flash

  .card
    .card-title Generate New Key
    form#key-form
      .form-row
        .form-group
          label Facility
          select.form-control#k-facility(required)
            option(value='') -- Select Facility --
        .form-group
          label Role to Grant
          select.form-control#k-role(required)
            option(value='pharmacist') Pharmacist
            option(value='facility_admin') Facility Admin
      .form-row
        .form-group
          label Max Uses
          input.form-control(type='number' id='k-uses' value='5' min='1' max='50')
        .form-group
          label Expires In (hours)
          input.form-control(type='number' id='k-hours' value='24' min='1' max='24')
          small(style='color:#8492a6;font-size:0.75rem') Max 24 hours
      button.btn.btn-success(type='submit') Generate Key
    #key-result

  .card
    .card-title
      span All Keys
      .card-title-actions
        select.form-control#filter-status(style='width:auto;font-size:0.8rem' onchange='applyFilters()')
          option(value='') All Status
          option(value='active') Active
          option(value='inactive') Inactive
          option(value='expired') Expired
        select.form-control#filter-role(style='width:auto;font-size:0.8rem;margin-left:0.5rem' onchange='applyFilters()')
          option(value='') All Roles
          option(value='pharmacist') Pharmacist
          option(value='facility_admin') Facility Admin
        button.btn.btn-sm.btn-ghost(onclick='loadKeys()' style='margin-left:0.5rem') ↻

    .table-wrapper
      table.mobile-stack
        thead
          tr
            th Facility
            th Code
            th Role
            th Uses
            th Expires
            th Status
            th Actions
        tbody#keys-table
          tr
            td(colspan='7')
              .loader
                .spinner
                |  Loading...

block scripts
  script.
    document.addEventListener('DOMContentLoaded', () => {
      let allKeys = [];

      const showFlash = (msg, type = 'success') => {
        const el = document.getElementById('key-flash');
        el.innerHTML = `<div class="flash flash-${type}" style="margin-bottom:1rem">${msg}</div>`;
        setTimeout(() => el.innerHTML = '', 4000);
      };

      // load facilities into dropdown
      fetch('/api/facilities', { credentials: 'include' })
        .then(r => r.json())
        .then(data => {
          const select = document.getElementById('k-facility');
          (data.facilities || []).forEach(f => {
            const opt       = document.createElement('option');
            opt.value       = f._id;
            opt.textContent = f.name;
            select.appendChild(opt);
          });
          // pre-fill from URL
          const params = new URLSearchParams(window.location.search);
          if (params.get('facility_id')) select.value = params.get('facility_id');
        });

      window.loadKeys = () => {
        fetch('/api/facility-keys', { credentials: 'include' })
          .then(r => r.json())
          .then(data => {
            allKeys = data.keys || [];
            applyFilters();
          });
      };

      window.applyFilters = () => {
        const statusF = document.getElementById('filter-status').value;
        const roleF   = document.getElementById('filter-role').value;
        const now     = new Date();

        let filtered = allKeys.filter(k => {
          const isExpired = new Date(k.expiresAt) < now;
          if (statusF === 'active')   return k.isActive && !isExpired;
          if (statusF === 'inactive') return !k.isActive && !isExpired;
          if (statusF === 'expired')  return isExpired;
          return true;
        });

        if (roleF) filtered = filtered.filter(k => k.role === roleF);
        renderKeys(filtered);
      };

      const renderKeys = (keys) => {
        const tbody = document.getElementById('keys-table');
        const now   = new Date();

        if (!keys.length) {
          tbody.innerHTML = '<tr><td colspan="7"><div class="empty-state"><p>No keys found</p></div></td></tr>';
          return;
        }

        tbody.innerHTML = keys.map(k => {
          const isExpired  = new Date(k.expiresAt) < now;
          const statusText = isExpired ? 'expired' : k.isActive ? 'active' : 'inactive';
          const badgeClass = isExpired ? 'badge-expired' : k.isActive ? 'badge-ok' : 'badge-declined';

          const expiresIn = isExpired
            ? '<span style="color:var(--danger)">Expired</span>'
            : new Date(k.expiresAt).toLocaleString('en-NG', { dateStyle:'short', timeStyle:'short' });

          let actions = '';
          if (!isExpired && k.isActive) {
            actions += `<button class="btn btn-sm btn-ghost" onclick="revokeKey('${k._id}')">Revoke</button>`;
          }
          actions += `<button class="btn btn-sm btn-danger" onclick="deleteKey('${k._id}')" style="margin-left:0.3rem">Delete</button>`;

          return `
            <tr>
              <td data-label="Facility">${k.facility_id ? k.facility_id.name : '—'}</td>
              <td data-label="Code">
                <code style="font-family:'DM Mono',monospace;font-weight:700;font-size:0.95rem;color:#0052CC;letter-spacing:1px">${k.code}</code>
              </td>
              <td data-label="Role">
                <span class="badge ${k.role === 'facility_admin' ? 'badge-confirmed' : 'badge-pending'}">
                  ${k.role === 'facility_admin' ? 'Facility Admin' : 'Pharmacist'}
                </span>
              </td>
              <td data-label="Uses">${k.usedCount} / ${k.maxUses}</td>
              <td data-label="Expires">${expiresIn}</td>
              <td data-label="Status"><span class="badge ${badgeClass}">${statusText}</span></td>
              <td data-label="Actions" style="white-space:nowrap">${actions}</td>
            </tr>
          `;
        }).join('');
      };

      window.revokeKey = async (id) => {
        const res  = await fetch(`/api/facility-keys/${id}/deactivate`, {
          method: 'PATCH', credentials: 'include',
        });
        const data = await res.json();
        if (res.ok) { showFlash('Key revoked'); loadKeys(); }
        else showFlash(data.message || 'Failed', 'error');
      };

      window.deleteKey = async (id) => {
        const res  = await fetch(`/api/admin/keys/${id}`, {
          method: 'DELETE', credentials: 'include',
        });
        const data = await res.json();
        if (res.ok) { showFlash('Key deleted'); loadKeys(); }
        else showFlash(data.message || 'Failed', 'error');
      };

      document.getElementById('key-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const hours = parseInt(document.getElementById('k-hours').value) || 24;
        if (hours > 24) {
          showFlash('Maximum expiry is 24 hours', 'error');
          return;
        }

        const res  = await fetch('/api/facility-keys/generate', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'include',
          body: JSON.stringify({
            facility_id:    document.getElementById('k-facility').value,
            role:           document.getElementById('k-role').value,
            maxUses:        parseInt(document.getElementById('k-uses').value),
            expiresInDays:  hours / 24,
          }),
        });
        const data = await res.json();

        if (res.ok) {
          document.getElementById('key-result').innerHTML = `
            <div class="flash flash-success" style="margin-top:1rem">
              ✓ Key generated for <strong>${data.key.facility}</strong>
              <div style="margin:0.75rem 0;padding:1rem;background:#EBF3FF;border-radius:8px;text-align:center">
                <div style="font-size:0.72rem;color:#8492a6;margin-bottom:0.3rem;text-transform:uppercase;letter-spacing:1px">Invite Code</div>
                <div style="font-size:2rem;font-weight:700;font-family:'DM Mono',monospace;color:#0052CC;letter-spacing:4px">${data.key.code}</div>
              </div>
              <small style="color:#8492a6">Role: ${data.key.role} · Uses: ${data.key.maxUses} · Expires: ${new Date(data.key.expiresAt).toLocaleString('en-NG', { dateStyle:'short', timeStyle:'short' })}</small>
            </div>`;
          document.getElementById('key-form').reset();
          loadKeys();
        } else {
          document.getElementById('key-result').innerHTML =
            `<div class="flash flash-error" style="margin-top:1rem">${data.message}</div>`;
        }
      });

      loadKeys();
    });